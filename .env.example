# Copy this file to .env and fill in your real values.
# .env is gitignored — your password never gets committed.

# MySQL connection (mysql:// URI). Database must already exist.
# Format: mysql://USER:PASSWORD@HOST:3306/DBNAME
DATABASE_URL=mysql://dbuser:YOUR_PASSWORD@localhost:3306/Budgets

# Secret used to sign session cookies. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# development | production  (production enables secure cookies — needs HTTPS)
NODE_ENV=development

# Port the server listens on
PORT=3000
